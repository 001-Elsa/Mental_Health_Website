APP_ENV=development
APP_NAME=心理健康AI助手
# Generate a unique value before any public deployment, e.g. `openssl rand -hex 32`.
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
METRICS_TOKEN=replace-with-a-separate-random-token
REQUEST_TIMEOUT_SECONDS=20
WEBSOCKET_MAX_CONNECTIONS=200
WEBSOCKET_MAX_CONNECTIONS_PER_IP=5
WEBSOCKET_IDLE_TIMEOUT_SECONDS=45

# Local fallback:
# DATABASE_URL=sqlite:///./mental_health_v2.db
# Docker Compose:
DATABASE_URL=postgresql+psycopg2://mental:mental@postgres:5432/mental_health
REDIS_URL=redis://redis:6379/0

# Docker Compose defaults below are for local demonstrations only. Override all
# of these values with non-default secrets before exposing a deployment publicly.
POSTGRES_DB=mental_health
POSTGRES_USER=mental
POSTGRES_PASSWORD=mental
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=mental-health-admin
# Required by docker-compose.prod.yml; do not use this development default.
REDIS_PASSWORD=change-me-in-production

DEEPSEEK_API_KEY=
DEEPSEEK_URL=https://api.deepseek.com/chat/completions
AI_CONNECT_TIMEOUT_SECONDS=5
AI_READ_TIMEOUT_SECONDS=45
AI_MAX_CONNECTIONS=50
AI_MAX_CONCURRENCY=8
AI_MAX_RETRIES=2
AI_RETRY_BASE_SECONDS=0.25
RISK_SLA_SCAN_SECONDS=30

SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=
SMS_SIGN_NAME=心灵伙伴
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_TOKEN=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
